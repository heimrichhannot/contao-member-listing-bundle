{
  "name": "heimrichhannot/contao-member-listing-bundle",
  "type": "contao-bundle",
  "description": "Add list and reader elements for members.",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": "^8.1",
    "contao/core-bundle": "^5.3",
    "doctrine/dbal": "^3.0 || ^4.0",
    "spatie/schema-org": "^3.0",
    "symfony/http-foundation": "^6.4 || ^7.0",
    "symfony/http-kernel": "^6.4 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "HeimrichHannot\\MemberListingBundle\\": "src/"
    }
  },
  "extra": {
    "contao-manager-plugin": "HeimrichHannot\\MemberListingBundle\\ContaoManager\\Plugin"
  },
  "config": {
    "allow-plugins": {
      "contao-components/installer": false,
      "php-http/discovery": false
    }
  },
  "require-dev": {
    "contao/manager-plugin": "^2.0",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-symfony": "^2.0"
  }
}
